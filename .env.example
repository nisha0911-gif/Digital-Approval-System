# Digital Approval System Configuration
# Copy this file to .env and update with your actual values

# Port (default: 3000)
PORT=3000

# Email Configuration (Optional - for sending actual emails)
# Leave these empty to run in TEST MODE (emails logged to console)

# Gmail Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# To use Gmail:
# 1. Enable 2-Step Verification on your Google Account
# 2. Create an App Password at https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password as EMAIL_PASS
# 4. Set EMAIL_USER to your Gmail address

# Alternative Email Services can be configured by modifying server.js
# ─────────────────────────────────────────────
#  Digital Approval System — Backend Config
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server port (default 3000)
PORT=3000

# ─── EMAIL CONFIG (Gmail recommended) ─────────
# Use your Gmail address
EMAIL_USER=your_gmail@gmail.com

# For Gmail: create an App Password (not your real password)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
# Generate a password for "Mail" → paste it here
EMAIL_PASS=your_16_digit_app_password

# Name shown as sender in the email
EMAIL_FROM_NAME=Digital Approval System

# ─── APP URL ──────────────────────────────────
# The URL where your frontend HTML file is served
# If running locally: http://localhost:3000
# If deployed: https://yourdomain.com
APP_URL=http://localhost:3000# Copy this file to .env and fill in your actual values

# Your computer's LAN IP address (e.g., 192.168.x.x)
# Get it with: ipconfig (look for IPv4 Address)
BASE_URL=http://YOUR_LAN_IP:3000

# For Heroku deployment
# BASE_URL=https://your-app-name.herokuapp.com

# Firebase service account JSON (for Heroku)
# FIREBASE_CONFIG={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Email credentials (for Heroku)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
